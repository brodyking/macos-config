# Finder
ctrl - 0x32 : open /System/Library/CoreServices/Finder.app
# Zen
ctrl + shift - 1 : open /Applications/Zen.app
ctrl + cmd - z : open /Applications/Zen.app
# Music
ctrl - 2 : open /System/Applications/Music.app
ctrl + cmd - m : open /System/Applications/Music.app
# Iterm
ctrl - 3 : open /Applications/iTerm.app
ctrl + cmd - return : open /Applications/iTerm.app
# Chrome
ctrl - 1 : open "/Applications/Google Chrome.app"
ctrl + cmd - c : open "/Applications/Google Chrome.app"
